# Public site URL (used for OG/canonical + NOWPayments callbacks)
NEXT_PUBLIC_SITE_URL=https://landing-pages-on-demand.prin7r.com

# Lead form webhook (Make/Zapier/n8n endpoint that dispatches the brief)
LEAD_WEBHOOK_URL=

# Plausible/PostHog/etc (optional)
NEXT_PUBLIC_ANALYTICS_DOMAIN=landing-pages-on-demand.prin7r.com

# NOWPayments hosted invoice (Wave 2 default crypto checkout rail).
# Get keys at https://nowpayments.io > Settings > API Keys + IPN.
# Server-side only — never expose to the browser.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# Admin API key — used for /api/admin/* endpoints (subscription management)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# Postmark — transactional email (onboarding + renewal invoices)
# Get token at https://account.postmarkapp.com/servers > API Tokens
POSTMARK_SERVER_TOKEN=

# Notion integration — sync paid subscriptions to DropHouse Subscriptions DB
# Create integration at https://www.notion.so/my-integrations
# Then share the target database with the integration
NOTION_TOKEN=
NOTION_DROPHOUSE_DSID=

# CORS origins (comma-separated, optional)
CORS_ORIGIN=https://landing-pages-on-demand.prin7r.com

# apps/app (open-saas) — placeholders only; full SaaS app deferred
DATABASE_URL=
JWT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
